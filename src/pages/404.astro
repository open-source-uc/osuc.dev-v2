---
import Layout from "@/layouts/Layout.astro";
import LinkButton from "@/components/LinkButton.astro";
---

<Layout
  title="Página no encontrada - Open Source UC"
  description="La página que buscas no existe."
>
  <main
    class="bg-background text-foreground flex min-h-screen flex-col items-center justify-center gap-8 px-10 py-20 lg:px-20 xl:px-50"
  >
    <div class="flex max-w-2xl flex-col items-center gap-6 text-center">
      <h1 class="text-primary text-6xl font-bold sm:text-8xl md:text-9xl">
        404
      </h1>
      <h2 class="text-2xl font-bold sm:text-3xl md:text-4xl">
        Página no encontrada
      </h2>
      <p class="text-foreground/80 px-4 text-base sm:text-lg md:text-xl">
        Lo sentimos, la página que estás buscando no existe o ha sido movida.
      </p>
      <div class="mt-4 flex flex-col gap-4 sm:flex-row">
        <LinkButton text="Volver al inicio" href="/" type="primary" />
        <LinkButton text="Sobre nosotros" href="/about" type="secondary" />
      </div>
    </div>
  </main>
</Layout>
