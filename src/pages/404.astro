---
import Layout from "@/layouts/Layout.astro";
import LinkButton from "@/components/LinkButton.astro";
---

<Layout
    title="Página no encontrada - Open Source UC"
    description="La página que buscas no existe."
>
    <main
        class="min-h-screen bg-background px-10 lg:px-20 xl:px-50 text-foreground flex flex-col justify-center items-center gap-8 py-20"
    >
        <div class="flex flex-col items-center gap-6 text-center max-w-2xl">
            <h1 class="text-6xl sm:text-8xl md:text-9xl font-bold text-primary">
                404
            </h1>
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold">
                Página no encontrada
            </h2>
            <p class="text-base sm:text-lg md:text-xl text-foreground/80 px-4">
                Lo sentimos, la página que estás buscando no existe o ha sido
                movida.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 mt-4">
                <LinkButton text="Volver al inicio" href="/" type="primary" />
                <LinkButton
                    text="Sobre nosotros"
                    href="/about"
                    type="secondary"
                />
            </div>
        </div>
    </main>
</Layout>
