---
import type { OldCoordData, CoordData } from "@/types/coords";
import Layout from "@/layouts/Layout.astro";
import coordsData from "@/data/coords.json";
import oldCoordsData from "@/data/old_coords.json";
import LeaderCard from "@/components/LeaderCard.astro";

oldCoordsData as OldCoordData[];
coordsData as CoordData[];
---

<Layout
  title="Sobre Open Source UC"
  description="Conoce más sobre Open Source UC, una iniciativa estudiantil de innovación tecnológica en la Pontificia Universidad Católica de Chile."
>
  <main class="flex w-full items-center justify-center px-4 sm:px-6">
    <section
      class="text-foreground flex w-full max-w-6xl flex-col justify-center gap-5 pt-15 pb-10"
    >
      <header class="flex flex-col gap-5">
        <h1 class="text-3xl font-bold sm:text-4xl">
          Sobre Open Source UC<span class="text-primary">.</span>
        </h1>
        <p class="text-sm sm:text-base">
          Open Source UC es una iniciativa estudiantil de innovación tecnológica
          que impulsa a estudiantes a colaborar y crecer profesionalmente a
          través de la filosofía open-source en la Pontificia Universidad
          Católica de Chile.
        </p>
      </header>
      <section aria-labelledby="why-we-exist" class="flex flex-col gap-5">
        <h2 id="why-we-exist" class="text-xl font-bold sm:text-2xl">
          ¿Por qué existimos?
        </h2>
        <ul
          class="flex list-outside list-disc flex-col gap-4 pl-5 text-sm sm:gap-5 sm:text-base"
        >
          <li>
            Creamos un espacio de aprendizaje práctico que permite a nuestros
            miembros ir más allá de los cursos universitarios, aplicando
            conocimientos en proyectos con impacto real y desarrollando
            habilidades que demanda la industria tecnológica.
          </li>
          <li>
            Construimos una comunidad de crecimiento mutuo donde se comparten
            experiencias, conocimientos y motivaciones. Al desarrollar de forma
            pública, Open Source reúne a estudiantes con diversos niveles de
            experiencia, fomentando el mentoring y la colaboración entre pares.
          </li>
          <li>
            Promovemos la transparencia y el aprendizaje abierto mediante
            proyectos de código abierto que no solo benefician a nuestra
            comunidad, sino que también contribuyen al ecosistema tecnológico
            regional y permiten que otros aprendan de nuestro trabajo.
          </li>
        </ul>
      </section>
      <section aria-labelledby="history" class="flex flex-col gap-5">
        <h2 id="history" class="text-xl font-bold sm:text-2xl">Historia</h2>
        <p class="text-sm sm:text-base">
          Desde el año 2006, existieron grupos como OpenPUC que buscaban
          incentivar el interés por el código abierto en la universidad. En el
          año 2017, un grupo de estudiantes - inspirados en OpenPUC - creó Open
          Source UC, organización que se mantuvo activa hasta finales del 2018.
          Desde el año 2021 se reorganizó la iniciativa, quedando en la
          comunidad que conocemos ahora.
        </p>
      </section>
      <section aria-labelledby="organization-chart" class="flex flex-col gap-5">
        <!-- Ref a content/resources/cargos-y-comunidad -->
        <h2 id="organization-chart" class="text-xl font-bold sm:text-2xl">
          Estructura Organizacional
        </h2>
        <p class="text-sm sm:text-base">
          Open Source UC se organiza de forma democrática y colaborativa, con
          una Asamblea de miembros, un Directorio que coordina la gestión, y
          roles operativos para eventos, proyectos y comunidad. Para conocer en
          detalle los cargos y responsabilidades, visita nuestra <a
            href="/org-chart"
            class="text-primary hover:underline"
            >página de estructura comunitaria</a
          >.
        </p>
      </section>
      <section
        id="actual-coordinators"
        aria-labelledby="actual-coordinators"
        class="flex flex-col gap-8"
      >
        <h2 class="text-xl font-bold sm:text-2xl">Coordinación actual</h2>
        <div
          class="grid items-center justify-between py-10 md:grid-cols-2 xl:grid-cols-3"
        >
          {
            coordsData[0].leaders.map((l) => (
              <LeaderCard name={l.name} github={l.github} role={l.role} />
            ))
          }
        </div>
      </section>
      <section
        aria-labelledby="coordinators-timeline"
        class="flex flex-col gap-5"
      >
        <h2 id="coordinators-timeline" class="text-xl font-bold sm:text-2xl">
          Timeline de Coordinadores
        </h2>
        <div class="relative flex flex-col gap-8 pl-4 sm:gap-10 sm:pl-5">
          <div
            class="bg-foreground absolute left-0 h-full w-0.5"
            aria-hidden="true"
          >
          </div>
          {
            oldCoordsData.map((semester, i) => {
              if (i == 0) return;
              return (
                <article
                  id={"semester-" + semester.year}
                  class="flex flex-col gap-4 sm:gap-5"
                >
                  <h3 class="text-primary text-lg font-bold sm:text-xl">
                    <time datetime={semester.year}>{semester.year}</time>
                  </h3>
                  <ul class="flex list-none flex-col gap-6 sm:gap-10">
                    {semester.leaders.map((leader) => {
                      const { name, description, githubUser } = leader;
                      return (
                        <li class="flex items-start gap-4 sm:items-center sm:gap-6">
                          <img
                            src={`https://github.com/${githubUser}.png`}
                            alt={`Foto de perfil de ${name}`}
                            class="size-12 shrink-0 rounded-full sm:size-15"
                            loading="lazy"
                            width="60"
                            height="60"
                          />
                          <div class="flex flex-col gap-1">
                            <h4 class="text-sm font-bold sm:text-base">
                              {name}
                            </h4>
                            <p class="text-foreground/80 text-xs sm:text-sm">
                              {description}
                            </p>
                            <a
                              href={`https://github.com/${githubUser}`}
                              class="text-primary text-xs hover:underline sm:text-sm"
                              target="_blank"
                              rel="noopener noreferrer"
                              aria-label={`Perfil de GitHub de ${name}`}
                            >
                              GitHub
                            </a>
                          </div>
                        </li>
                      );
                    })}
                  </ul>
                </article>
              );
            })
          }
        </div>
      </section>
    </section>
  </main>
</Layout>
