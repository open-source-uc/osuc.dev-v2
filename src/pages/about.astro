---
import type { OldCoordData } from "@/types/coords";
import Layout from "@/layouts/Layout.astro";
import coordsData from "@/data/coords.json";
import LeaderCard from "@/components/LeaderCard.astro";

const coords = coordsData as unknown as OldCoordData[];
---

<Layout
  title="Sobre Open Source UC"
  description="Conoce más sobre Open Source UC, una iniciativa estudiantil de innovación tecnológica en la Pontificia Universidad Católica de Chile."
  className="overflow-x-hidden"
>
  <main
    class="text-foreground relative flex w-full flex-col items-center justify-center px-4 sm:px-6"
  >
    <section
      class="relative grid h-[70vh] w-screen max-w-full items-center justify-center"
    >
      <div
        class="from-primary/60 to-primary/10 absolute -top-3/4 left-1/2 z-10 h-[110vh] w-[135vh] max-w-full -translate-x-1/2 rounded-full bg-radial blur-3xl"
        aria-hidden="true"
      >
      </div>
      <h2 class="z-30 text-2xl font-bold md:text-4xl">
        About Open Source <span class="text-primary">eUC</span>
      </h2>
    </section>
    <section
      class="grid p-10 md:p-20 xl:grid-cols-3"
      aria-labelledby="mission y vision"
    >
      <section aria-labelledby="mission" class="flex flex-col gap-5 p-5">
        <h2 id="mission" class="text-xl font-bold md:text-4xl">
          Nuestra Misión
        </h2>
        <p class="text-md md:text-xl">
          Nuestra misión es potenciar a la comunidad estudiantil a través del
          aprendizaje técnico colaborativo, construyendo juntos proyectos open
          source que resuelvan problemas reales.
        </p>
      </section>
      <section aria-labelledby="proposito" class="flex flex-col gap-5 p-5">
        <h2 id="proposito" class="text-xl font-bold md:text-4xl">
          Nuestro Propósito
        </h2>
        <p class="text-md md:text-xl">
          Nuestro propósito es aportar a la comunidad mediante proyectos open
          source que resuelvan necesidades reales, fortalezcan la colaboración
          entre estudiantes y generen un impacto positivo y abierto dentro y
          fuera de la universidad.
        </p>
      </section>
      <section aria-labelledby="vision" class="flex flex-col gap-5 p-5">
        <h2 id="vision" class="text-xl font-bold md:text-4xl">
          Nuestra Visión
        </h2>
        <p class="text-md md:text-xl">
          Aspiramos a ser la comunidad de referencia en innovación tecnológica
          estudiantil, donde cada miembro pueda crecer, colaborar y dejar una
          huella significativa en la comunidad.
        </p>
      </section>
    </section>
    <section class="flex w-full flex-col gap-4 p-5 md:p-10" id="actual-coord">
      <h2 class="text-center text-xl font-bold md:text-4xl">
        Coordinación actual
      </h2>
      <p class="px-10 text-center md:text-xl">
        Si quieres revisar el organigrama, puedes hacerlo <a
          href="/org-chart"
          class="text-primary hover:underline">aquí</a
        >.
      </p>
      <div
        class="grid items-center justify-between gap-5 py-10 md:grid-cols-2 md:p-10 xl:grid-cols-3"
      >
        {
          coords[0].leaders.map((l) => (
            <LeaderCard
              name={l.name}
              role={l.role}
              description={l.description}
              github={l.github}
              linkedin={l.linkedin}
              instagram={l.instagram}
              className="h-full"
            />
          ))
        }
      </div>
    </section>
    <section
      aria-labelledby="history"
      class="flex w-full flex-col gap-5 p-10 pb-0 md:p-20"
    >
      <div class="flex flex-col gap-5 text-center">
        <h2 id="history" class="text-xl font-bold md:text-4xl">Historia</h2>
        <p class="text-md md:text-xl">
          Desde el año 2006, existieron grupos como OpenPUC que buscaban
          incentivar el interés por el código abierto en la universidad. En el
          año 2017, un grupo de estudiantes - inspirados en OpenPUC - creó Open
          Source UC, organización que se mantuvo activa hasta finales del 2018.
          Desde el año 2021 se reorganizó la iniciativa, quedando en la
          comunidad que conocemos ahora.
        </p>
      </div>
      <h3
        id="coordinators-timeline"
        class="px-20 pt-20 text-center text-xl font-bold sm:text-4xl"
      >
        Timeline de Coordinadores
      </h3>
    </section>
  </main>
  <section
    aria-labelledby="coordinators-timeline"
    class="js-scroll-section text-foreground relative h-screen w-screen overflow-hidden"
  >
    <div class="js-scroll-container flex h-full" style="width: max-content;">
      {
        coords.slice(1).map((s) => (
          <div
            class="js-panel flex h-full flex-col px-10 pt-24 pb-10"
            style="width: 100vw;"
          >
            <div class="mb-6 text-2xl font-bold">{s.year}</div>
            <div class="flex flex-wrap items-start gap-5">
              {s.leaders.map((l) => (
                <LeaderCard
                  name={l.name}
                  role={l.role}
                  description={l.description}
                  github={l.github}
                  linkedin={l.linkedin}
                  instagram={l.instagram}
                  className="w-72 shrink-0"
                />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>

<script>
  import "@/utils/horizontalScroll";
</script>
